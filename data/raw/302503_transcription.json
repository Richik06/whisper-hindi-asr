[
  {
    "start": 0.65,
    "end": 1.76,
    "speaker_id": 102673,
    "text": "क्या"
  },
  {
    "start": 5.18,
    "end": 6.23,
    "speaker_id": 102673,
    "text": "पैकेट में क्या रहता है।"
  },
  {
    "start": 8.69,
    "end": 21.35,
    "speaker_id": 102673,
    "text": "हा हा ह क्रिकेट के बारे में क्रिकेट में ग्यारह खिलाड़ी होते हैं और होते है बाउंड्री होती हैं उसमें वी कैन हिट सिक्स और फोर्स"
  },
  {
    "start": 22.01,
    "end": 27.53,
    "speaker_id": 102673,
    "text": "हम चौके छक्के मारते हैं उसमें सिक्स हां सिक्स बॉल्स का एक ओवर होता है"
  },
  {
    "start": 34.16,
    "end": 36.8,
    "speaker_id": 102673,
    "text": "हू अ"
  },
  {
    "start": 39.53,
    "end": 51.26,
    "speaker_id": 102673,
    "text": "अप्रॉक्स सैवेन विथ वेरी करती है कि तुम स्ट्रेट मार रहे हो लैग मार रहे हो ऑफ मार रहे हो या बैक मार रहे हो जी लौंग में अप्रॉक्स से से सैवेंटी या ऐटी"
  },
  {
    "start": 56.42,
    "end": 57.44,
    "speaker_id": 102673,
    "text": "जी"
  },
  {
    "start": 62.06,
    "end": 63.5,
    "speaker_id": 102673,
    "text": "हां मतलब रॉक्स एटी।"
  },
  {
    "start": 71.72,
    "end": 86.24,
    "speaker_id": 102673,
    "text": "हम्म जी"
  },
  {
    "start": 86.75,
    "end": 98.9,
    "speaker_id": 102673,
    "text": "हूं जी"
  },
  {
    "start": 100.49,
    "end": 115.25,
    "speaker_id": 102673,
    "text": "REDACTED"
  },
  {
    "start": 115.46,
    "end": 130.34,
    "speaker_id": 102673,
    "text": "जी क्या मतलब तेरा खेलते हैं और सब हम्म"
  },
  {
    "start": 132.17,
    "end": 146.45,
    "speaker_id": 102673,
    "text": "क्या मन खिलाड़ी अच्छा अच्छा सचिन तेंदुलकर जी जी सर"
  },
  {
    "start": 146.48,
    "end": 149.57,
    "speaker_id": 102673,
    "text": "गॉड आफ क्रिकेट"
  },
  {
    "start": 151.73,
    "end": 152.51,
    "speaker_id": 102673,
    "text": "क्या"
  },
  {
    "start": 154.76,
    "end": 165.56,
    "speaker_id": 102673,
    "text": "सबसे ज्यादा शायद रोहित शर्मा है ना ओल्डिस्ट तो विराट कोहली अच्छा"
  },
  {
    "start": 168.74,
    "end": 173.78,
    "speaker_id": 102673,
    "text": "हु जी आर सी बी नही"
  },
  {
    "start": 175.91,
    "end": 190.73,
    "speaker_id": 102673,
    "text": "ह्म्म ऐसे तो पता नहीं ऑरेंज कैप की शैली थी अच्छा"
  },
  {
    "start": 191.45,
    "end": 205.4,
    "speaker_id": 102673,
    "text": "हूं अच्छा हूं"
  },
  {
    "start": 205.67,
    "end": 215.78,
    "speaker_id": 102673,
    "text": "ह्म्म्म नई लास्ट वाला नहीं देखा मैंने कोई सपना लोग जी हम्म नई पता मेरे को"
  },
  {
    "start": 218.15,
    "end": 230.21,
    "speaker_id": 102673,
    "text": "और बताइए क्या हा वॉलीवॉल वॉलीवॉल"
  },
  {
    "start": 233.09,
    "end": 247.64,
    "speaker_id": 102673,
    "text": "हम्म जिसमें सिक्स प्लेयर्स होते हैं और थ्री और इन एक्स एक्स्ट्रा जी"
  },
  {
    "start": 257.06,
    "end": 257.69,
    "speaker_id": 102673,
    "text": "क्याआआ"
  },
  {
    "start": 259.91,
    "end": 274.79,
    "speaker_id": 102673,
    "text": "हूम हूम कबड्डी हॉकी सोरी"
  },
  {
    "start": 274.97,
    "end": 286.88,
    "speaker_id": 102673,
    "text": "जी जी आ रही आ रही ह हॉकी में ग्यारह ही होते हैं"
  },
  {
    "start": 292.67,
    "end": 295.43,
    "speaker_id": 102673,
    "text": "हूं जी"
  },
  {
    "start": 304.82,
    "end": 310.4,
    "speaker_id": 102673,
    "text": "रुनाल्डो मैसी नेमार"
  },
  {
    "start": 321.5,
    "end": 322.22,
    "speaker_id": 102673,
    "text": "क्या क्या"
  },
  {
    "start": 325.22,
    "end": 337.07,
    "speaker_id": 102673,
    "text": "जी लगभग सारी देखे हैं जी और आप कोनसा और आपने कौन से देखे हैं।"
  },
  {
    "start": 343.7,
    "end": 344.75,
    "speaker_id": 102673,
    "text": "जी जी"
  },
  {
    "start": 347.06,
    "end": 360.89,
    "speaker_id": 102673,
    "text": "जैबलिंग थ्रो"
  },
  {
    "start": 370.79,
    "end": 383.99,
    "speaker_id": 102673,
    "text": "हम्म बेसबॉल बास्केटबॉल जी"
  },
  {
    "start": 384.02,
    "end": 395.18,
    "speaker_id": 102673,
    "text": "और हमारे टॉपिक्स क्या क्या है सड़क किनारे के खाने के यादें दोस्त के साथ हम्म प्रिश शेयर करना परिवार की परंपराओं को हम्म"
  },
  {
    "start": 398.69,
    "end": 401.63,
    "speaker_id": 102673,
    "text": "परंपराओं को सीढ़ी दर सीढी चलाना।"
  },
  {
    "start": 403.91,
    "end": 406.82,
    "speaker_id": 102673,
    "text": "हां ये तो है यही था हमारा मेंन टॉपिक तो"
  },
  {
    "start": 410.96,
    "end": 411.89,
    "speaker_id": 102673,
    "text": "हां जी जी"
  },
  {
    "start": 416.0,
    "end": 418.58,
    "speaker_id": 102673,
    "text": "जी जी"
  },
  {
    "start": 421.22,
    "end": 421.94,
    "speaker_id": 102673,
    "text": "ओके ओके"
  }
]